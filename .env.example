# Kato agent application
KATO_ISSUE_PLATFORM=youtrack
# Selects which agent runs the implementation/testing/review work.
# Supported values: openhands (default) | claude
# - openhands: drives the OpenHands HTTP server (uses the OPENHANDS_* settings below).
# - claude:    drives Anthropic's Claude Code CLI locally (`claude -p`); uses the
#              KATO_CLAUDE_* settings further down. The OPENHANDS_* block can stay
#              empty when this is set to `claude`.
KATO_AGENT_BACKEND=openhands
KATO_LOG_LEVEL=warning
KATO_WORKFLOW_LOG_LEVEL=info
KATO_EXTERNAL_API_MAX_RETRIES=5
# Per-task workspace folders. Each task gets a subdirectory named after
# its ticket id (e.g. PROJ-12) containing fresh clones of every repo it
# touches. Empty = ~/.kato/workspaces. The planning UI's tab list reads
# from this root: one folder = one tab.
KATO_WORKSPACES_ROOT=
# How many tasks the orchestrator processes in parallel. The main scan
# thread still validates and reserves slots one-at-a-time; only the
# heavy execute / test / publish work runs concurrently.
KATO_MAX_PARALLEL_TASKS=1
# Comma-separated folder names to exclude from repository auto-discovery.
KATO_IGNORED_REPOSITORY_FOLDERS=
# Generated from the repository source fingerprint helper.
KATO_SOURCE_FINGERPRINT=
KATO_FAILURE_EMAIL_ENABLED=false
KATO_FAILURE_EMAIL_TEMPLATE_ID=0
KATO_FAILURE_EMAIL_TO=
KATO_FAILURE_EMAIL_SENDER_NAME=Kato
KATO_FAILURE_EMAIL_SENDER_EMAIL=noreply@example.com
KATO_COMPLETION_EMAIL_ENABLED=false
KATO_COMPLETION_EMAIL_TEMPLATE_ID=0
KATO_COMPLETION_EMAIL_TO=
KATO_COMPLETION_EMAIL_SENDER_NAME=Kato
KATO_COMPLETION_EMAIL_SENDER_EMAIL=noreply@example.com
KATO_AGENT_SERVER_IMAGE_REPOSITORY=
KATO_AGENT_SERVER_IMAGE_TAG=
# Host port that publishes the Kato planning UI webserver (Flask) when running
# under docker compose. Inside the container the webserver always binds 0.0.0.0.
KATO_WEBSERVER_PORT=5050
# Claude Code CLI backend (used only when KATO_AGENT_BACKEND=claude).
# Install Claude Code: https://docs.claude.com/en/docs/claude-code/setup
#
# Auth — pick ONE:
#   (A) Max/Pro plan, recommended for Docker: run `claude setup-token` on the
#       host, copy the printed token into CLAUDE_CODE_OAUTH_TOKEN below. This
#       bills your subscription, not the API balance, and survives into the
#       container (the macOS Keychain does not).
#   (B) Pay-per-token API: set ANTHROPIC_API_KEY. Required only if you don't
#       have a Max/Pro plan, or for headless servers without browser access.
#   (C) Local interactive (only `make run`, not Docker): run `claude login`
#       once on the host. The Kato process inherits your Keychain credentials.
# Path to the `claude` binary. Plain `claude` works when it is on PATH.
KATO_CLAUDE_BINARY=claude
# Optional model override. Leave empty to use Claude Code's configured default.
# Example: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
KATO_CLAUDE_MODEL=
# Optional cap on agent turns per task; empty means no cap.
KATO_CLAUDE_MAX_TURNS=
# Reasoning depth knob passed via `--effort`.
# Accepted: low | medium | high | xhigh | max. Empty = Claude's default.
# Higher levels burn more tokens / time but think harder before acting.
KATO_CLAUDE_EFFORT=
# Optional comma-separated allow/deny tool lists passed to `--allowedTools` / `--disallowedTools`.
# When KATO_CLAUDE_BYPASS_PERMISSIONS=false, an empty allow list is replaced at
# runtime with a safe default (Edit,Write,Read,Bash,Glob,Grep) so the headless
# `claude -p` agent does not stall asking for permission mid-task.
KATO_CLAUDE_ALLOWED_TOOLS=
KATO_CLAUDE_DISALLOWED_TOOLS=
# Opt-in to `--permission-mode bypassPermissions` (a.k.a. --dangerously-skip-permissions).
# Default false → uses the safer `acceptEdits` mode plus the pre-approved tools list.
# Note: bypassPermissions is refused when the process runs as root.
KATO_CLAUDE_BYPASS_PERMISSIONS=false
# Per-task subprocess timeout for the Claude CLI in seconds.
KATO_CLAUDE_TIMEOUT_SECONDS=1800
# Run a startup smoke test prompt to verify model access. Off by default to avoid spend.
KATO_CLAUDE_MODEL_SMOKE_TEST_ENABLED=false

YOUTRACK_BASE_URL=https://your-company.youtrack.cloud
YOUTRACK_TOKEN=
YOUTRACK_PROJECT=PROJ
YOUTRACK_ASSIGNEE=your-youtrack-login
YOUTRACK_PROGRESS_STATE_FIELD=State
YOUTRACK_PROGRESS_STATE=In Progress
YOUTRACK_REVIEW_STATE_FIELD=State
YOUTRACK_REVIEW_STATE=To Verify
YOUTRACK_ISSUE_STATES=Todo,Open

JIRA_BASE_URL=
JIRA_TOKEN=
JIRA_EMAIL=
JIRA_PROJECT=
JIRA_ASSIGNEE=
JIRA_PROGRESS_STATE_FIELD=status
JIRA_PROGRESS_STATE=In Progress
JIRA_REVIEW_STATE_FIELD=status
JIRA_REVIEW_STATE=In Review
JIRA_ISSUE_STATES=To Do,Open

GITHUB_ISSUES_BASE_URL=https://api.github.com
GITHUB_API_TOKEN=
GITHUB_ISSUES_OWNER=
GITHUB_ISSUES_REPO=
GITHUB_ISSUES_ASSIGNEE=
GITHUB_ISSUES_PROGRESS_STATE_FIELD=labels
GITHUB_ISSUES_PROGRESS_STATE=In Progress
GITHUB_ISSUES_REVIEW_STATE_FIELD=labels
GITHUB_ISSUES_REVIEW_STATE=In Review
GITHUB_ISSUES_ISSUE_STATES=open
# Also used for GitHub pull request API access when discovered repositories live on GitHub.

GITLAB_ISSUES_BASE_URL=https://gitlab.com/api/v4
GITLAB_API_TOKEN=
GITLAB_ISSUES_PROJECT=
GITLAB_ISSUES_ASSIGNEE=
GITLAB_ISSUES_PROGRESS_STATE_FIELD=labels
GITLAB_ISSUES_PROGRESS_STATE=In Progress
GITLAB_ISSUES_REVIEW_STATE_FIELD=labels
GITLAB_ISSUES_REVIEW_STATE=In Review
GITLAB_ISSUES_ISSUE_STATES=opened
# Also used for GitLab merge request API access when discovered repositories live on GitLab.

BITBUCKET_ISSUES_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_API_TOKEN=
BITBUCKET_USERNAME=
# BITBUCKET_USERNAME is used for git push auth.
BITBUCKET_API_EMAIL=
# BITBUCKET_API_EMAIL is used for Bitbucket REST API auth.
BITBUCKET_ISSUES_WORKSPACE=
BITBUCKET_ISSUES_REPO_SLUG=
BITBUCKET_ISSUES_ASSIGNEE=
BITBUCKET_ISSUES_PROGRESS_STATE_FIELD=state
BITBUCKET_ISSUES_PROGRESS_STATE=open
BITBUCKET_ISSUES_REVIEW_STATE_FIELD=state
BITBUCKET_ISSUES_REVIEW_STATE=resolved
BITBUCKET_ISSUES_ISSUE_STATES=new,open
# Also used for Bitbucket pull request API access when discovered repositories live on Bitbucket.

# Root folder containing checked-out repositories. The agent scans this folder
# and matches repository or folder names from the task description.
# Pull request provider examples:
# Bitbucket: https://api.bitbucket.org/2.0
# GitHub: https://api.github.com
# GitLab: https://gitlab.com/api/v4
REPOSITORY_ROOT_PATH=.
MOUNT_DOCKER_DATA_ROOT=./mount_docker_data
OPENHANDS_BASE_URL=http://localhost:3000
OPENHANDS_API_KEY=local
OPENHANDS_SKIP_TESTING=false
OPENHANDS_TESTING_CONTAINER_ENABLED=false
OPENHANDS_TESTING_BASE_URL=http://localhost:3001
OPENHANDS_TESTING_PORT=3001
# Defaults used by the `openhands` Docker Compose service.
OPENHANDS_CONTAINER_LOG_ALL_EVENTS=true
EMAIL_CORE_LIB_SEND_IN_BLUE_API_KEY=
SLACK_WEBHOOK_URL_ERRORS_EMAIL=

# OpenHands container
OPENHANDS_PORT=3000
OPENHANDS_PULL_POLICY=missing
OPENHANDS_LOG_LEVEL=error
# Set a stable random secret so OpenHands can persist secrets safely across restarts.
OH_SECRET_KEY=
# Host path for OpenHands state storage. Prefer an absolute path when overriding.
OPENHANDS_STATE_DIR=~/.openhands
OPENHANDS_WEB_URL=http://localhost:3000
OPENHANDS_RUNTIME=docker
# Host SSH agent socket path for SSH git remotes such as git@bitbucket.org:...
# Docker Desktop on macOS exposes this path by default.
OPENHANDS_SSH_AUTH_SOCK_HOST_PATH=/run/host-services/ssh-auth.sock

# OpenHands LLM configuration
# Example OpenAI model: openai/gpt-4o
# Example OpenHands Cloud model: openhands/claude-sonnet-4-20250514
OPENHANDS_LLM_MODEL=
OPENHANDS_LLM_API_KEY=
OPENHANDS_LLM_BASE_URL=
OPENHANDS_MODEL_SMOKE_TEST_ENABLED=true
OPENHANDS_TESTING_LLM_MODEL=
OPENHANDS_TESTING_LLM_API_KEY=
OPENHANDS_TESTING_LLM_BASE_URL=
OPENHANDS_LLM_API_VERSION=
OPENHANDS_LLM_NUM_RETRIES=
OPENHANDS_LLM_TIMEOUT=
OPENHANDS_POLL_INTERVAL_SECONDS=2.0
OPENHANDS_MAX_POLL_ATTEMPTS=900
OPENHANDS_TASK_SCAN_STARTUP_DELAY_SECONDS=30
OPENHANDS_TASK_SCAN_INTERVAL_SECONDS=60
OPENHANDS_LLM_DISABLE_VISION=
OPENHANDS_LLM_DROP_PARAMS=
OPENHANDS_LLM_CACHING_PROMPT=

# Optional AWS credentials for Bedrock-backed LLM setups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
AWS_SESSION_TOKEN=
AWS_BEARER_TOKEN_BEDROCK=
